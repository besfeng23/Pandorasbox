# ═══════════════════════════════════════════════════════════════════════════
# PANDORA'S BOX - HYBRID-NATIVE AI SYSTEM CONFIGURATION
# "Two-Brain System" Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🌌 LOCAL BRAIN (UNIVERSE AGENT) - Deep Thinking, Roleplay, Personality
# ─────────────────────────────────────────────────────────────────────────────
# Self-hosted infrastructure via Ollama/vLLM
LOCAL_INFERENCE_URL=http://10.128.0.4:11434/v1
LOCAL_INFERENCE_MODEL=mistral

# Legacy aliases (for backwards compatibility)
INFERENCE_URL=http://10.128.0.4:11434/v1
INFERENCE_MODEL=mistral

# Optional: API key for authenticated inference (vLLM)
SOVEREIGN_KEY=empty

# ─────────────────────────────────────────────────────────────────────────────
# ☁️ CLOUD BRAIN (BUILDER AGENT) - Fast Utility, Coding, Summarization
# ─────────────────────────────────────────────────────────────────────────────
# Groq Cloud - Fastest inference for structured tasks
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq Model Selection
GROQ_MODEL_COMPLEX=llama-3.3-70b-versatile      # Complex tasks, coding
GROQ_MODEL_FAST=llama-3.1-8b-instant            # Routing, classification
GROQ_MODEL_WHISPER=whisper-large-v3             # Speech-to-text

# ─────────────────────────────────────────────────────────────────────────────
# 🧠 MEMORY SUBSYSTEM (QDRANT VECTOR DATABASE)
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_URL=http://10.128.0.3:6333
QDRANT_COLLECTION=memories
QDRANT_DIMENSION=384

# Embeddings Service
EMBEDDINGS_BASE_URL=https://pandora-embeddings-service-536979070288.us-central1.run.app
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────────────────
# 🔥 FIREBASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin (use Secret Manager in production)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 SECURITY & AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────
# Cron job secret for secure background tasks
CRON_SECRET=your-secure-cron-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 EXTERNAL SERVICES
# ─────────────────────────────────────────────────────────────────────────────
# Tavily Search API (web retrieval)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─────────────────────────────────────────────────────────────────────────────
# 📡 RUNTIME CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
HOSTNAME=0.0.0.0
NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:9002
